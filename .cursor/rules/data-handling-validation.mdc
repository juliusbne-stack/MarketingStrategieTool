## 3. Data Validation - Zod Required

**Rule:** ALL data passed to Server Actions MUST be validated using Zod schemas.

### Validation Pattern

1. **Define Zod schema** for the input
2. **Infer TypeScript type** from schema using `z.infer<>`
3. **Use type for function parameter**
4. **Parse input with schema** using `.parse()` or `.safeParse()`
5. **Use validated data** for database operations

### ✅ Complete Example

```typescript
"use server";

import { z } from "zod";
import { auth } from "@clerk/nextjs/server";
import { db } from "@/db";
import { cardsTable } from "@/db/schema";
import { revalidatePath } from "next/cache";

// 1. Define validation schema
const createCardSchema = z.object({
  deckId: z.number().int().positive(),
  front: z.string().min(1, "Question is required").max(1000),
  back: z.string().min(1, "Answer is required").max(1000),
});

// 2. Infer TypeScript type
type CreateCardInput = z.infer<typeof createCardSchema>;

// 3. Use typed parameter
export async function createCard(input: CreateCardInput) {
  const { userId } = await auth();
  
  if (!userId) {
    throw new Error("Unauthorized");
  }
  
  // 4. Parse and validate
  const validated = createCardSchema.parse(input);
  
  // TODO: Verify user owns the deck (see data-access-security.mdc)
  
  // 5. Use validated data
  const [newCard] = await db
    .insert(cardsTable)
    .values({
      deckId: validated.deckId,
      front: validated.front,
      back: validated.back,
    })
    .returning();
  
  revalidatePath(`/decks/${validated.deckId}`);
  
  return newCard;
}
```

### Using safeParse for Better Error Handling

```typescript
export async function createCard(input: CreateCardInput) {
  const { userId } = await auth();
  
  if (!userId) {
    return { success: false, error: "Unauthorized" };
  }
  
  // Use safeParse for error handling without throwing
  const result = createCardSchema.safeParse(input);
  
  if (!result.success) {
    return {
      success: false,
      error: "Validation failed",
      details: result.error.format(),
    };
  }
  
  const validated = result.data;
  
  try {
    const [newCard] = await db
      .insert(cardsTable)
      .values({
        deckId: validated.deckId,
        front: validated.front,
        back: validated.back,
      })
      .returning();
    
    revalidatePath(`/decks/${validated.deckId}`);
    
    return { success: true, data: newCard };
  } catch (error) {
    return { success: false, error: "Database error" };
  }
}
```

