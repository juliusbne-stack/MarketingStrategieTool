## 5. Common Validation Schemas

### Reusable Validation Patterns

```typescript
// lib/validations/common.ts
import { z } from "zod";

export const idSchema = z.number().int().positive();

export const titleSchema = z
  .string()
  .min(1, "Title is required")
  .max(100, "Title must be 100 characters or less")
  .trim();

export const descriptionSchema = z
  .string()
  .max(500, "Description must be 500 characters or less")
  .trim()
  .optional();

export const flashcardTextSchema = z
  .string()
  .min(1, "This field is required")
  .max(1000, "Text must be 1000 characters or less")
  .trim();
```

```typescript
// lib/validations/deck-validations.ts
import { z } from "zod";
import { idSchema, titleSchema, descriptionSchema } from "./common";

export const createDeckSchema = z.object({
  title: titleSchema,
  description: descriptionSchema,
});

export const updateDeckSchema = z.object({
  id: idSchema,
  title: titleSchema,
  description: descriptionSchema,
});

export const deleteDeckSchema = z.object({
  id: idSchema,
});

// Export types
export type CreateDeckInput = z.infer<typeof createDeckSchema>;
export type UpdateDeckInput = z.infer<typeof updateDeckSchema>;
export type DeleteDeckInput = z.infer<typeof deleteDeckSchema>;
```

