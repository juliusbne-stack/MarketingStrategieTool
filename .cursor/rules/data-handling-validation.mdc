## 2. Data Mutations - Server Actions Only

**Rule:** All database inserts, updates, and deletes MUST be performed through Server Actions.

### ✅ Correct Pattern

```typescript
// app/actions/deck-actions.ts
"use server";

import { auth } from "@clerk/nextjs/server";
import { db } from "@/db";
import { decksTable } from "@/db/schema";
import { eq, and } from "drizzle-orm";
import { revalidatePath } from "next/cache";
import { z } from "zod";

// Define validation schema
const createDeckSchema = z.object({
  title: z.string().min(1, "Title is required").max(100),
  description: z.string().max(500).optional(),
});

// Type inferred from schema
type CreateDeckInput = z.infer<typeof createDeckSchema>;

export async function createDeck(input: CreateDeckInput) {
  // 1. Authenticate user
  const { userId } = await auth();
  
  if (!userId) {
    throw new Error("Unauthorized");
  }
  
  // 2. Validate input with Zod
  const validated = createDeckSchema.parse(input);
  
  // 3. Perform database mutation
  const [newDeck] = await db
    .insert(decksTable)
    .values({
      userId,
      title: validated.title,
      description: validated.description,
    })
    .returning();
  
  // 4. Revalidate affected paths
  revalidatePath("/decks");
  
  return newDeck;
}

// Update example
const updateDeckSchema = z.object({
  id: z.number().int().positive(),
  title: z.string().min(1).max(100),
  description: z.string().max(500).optional(),
});

type UpdateDeckInput = z.infer<typeof updateDeckSchema>;

export async function updateDeck(input: UpdateDeckInput) {
  const { userId } = await auth();
  
  if (!userId) {
    throw new Error("Unauthorized");
  }
  
  const validated = updateDeckSchema.parse(input);
  
  // Verify ownership and update
  const result = await db
    .update(decksTable)
    .set({
      title: validated.title,
      description: validated.description,
      updatedAt: new Date(),
    })
    .where(
      and(
        eq(decksTable.id, validated.id),
        eq(decksTable.userId, userId)
      )
    )
    .returning();
  
  if (result.length === 0) {
    throw new Error("Deck not found or unauthorized");
  }
  
  revalidatePath("/decks");
  revalidatePath(`/decks/${validated.id}`);
  
  return result[0];
}

// Delete example
const deleteDeckSchema = z.object({
  id: z.number().int().positive(),
});

type DeleteDeckInput = z.infer<typeof deleteDeckSchema>;

export async function deleteDeck(input: DeleteDeckInput) {
  const { userId } = await auth();
  
  if (!userId) {
    throw new Error("Unauthorized");
  }
  
  const validated = deleteDeckSchema.parse(input);
  
  const result = await db
    .delete(decksTable)
    .where(
      and(
        eq(decksTable.id, validated.id),
        eq(decksTable.userId, userId)
      )
    )
    .returning();
  
  if (result.length === 0) {
    throw new Error("Deck not found or unauthorized");
  }
  
  revalidatePath("/decks");
  
  return result[0];
}
```

### ❌ Wrong Patterns

```typescript
// ❌ DON'T use API routes for mutations
// app/api/decks/route.ts
export async function POST(request: Request) {
  const body = await request.json();
  // ❌ Avoid this pattern - use Server Actions instead
  await db.insert(decksTable).values(body);
  return Response.json({ success: true });
}

// ❌ DON'T accept FormData as the type
"use server";

export async function createDeck(formData: FormData) { // ❌ Wrong type
  const title = formData.get("title") as string;
  // ❌ No type safety, no validation
}

// ❌ DON'T skip validation
"use server";

export async function createDeck(title: string, description: string) {
  const { userId } = await auth();
  
  // ❌ No validation with Zod
  await db.insert(decksTable).values({
    userId,
    title, // Unvalidated input
    description,
  });
}
```

