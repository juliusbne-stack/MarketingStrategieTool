                    "type": "object",
                    "properties": {
                      "promise": { "type": "string", "maxLength": 160 },
                      "values": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                      "personality": { "type": "array", "items": { "type": "string" }, "maxItems": 4 },
                      "voice": {
                        "type": "object",
                        "properties": {
                          "tone": { "type": "string", "maxLength": 80 },
                          "style_rules": { "type": "array", "items": { "type": "string" }, "maxItems": 5 },
                          "do": { "type": "array", "items": { "type": "string" }, "maxItems": 4 },
                          "dont": { "type": "array", "items": { "type": "string" }, "maxItems": 4 }
                        },
                        "required": ["tone", "style_rules", "do", "dont"]
                      },
                      "prism": {
                        "type": "object",
                        "properties": {
                          "physique": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "personality": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "culture": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "relationship": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "reflection": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "self_image": { "type": "array", "items": { "type": "string" }, "maxItems": 3 }
                        },
                        "required": ["physique", "personality", "culture", "relationship", "reflection", "self_image"]
                      },
                      "brand_wheel": {
                        "type": "object",
                        "properties": {
                          "attributes": { "type": "array", "items": { "type": "string" }, "maxItems": 4 },
                          "benefits": { "type": "array", "items": { "type": "string" }, "maxItems": 4 },
                          "values": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
                          "essence": { "type": "string", "maxLength": 60 }
                        },
                        "required": ["attributes", "benefits", "values", "essence"]
                      }
                    },
                    "required": ["promise", "values", "personality", "voice", "prism", "brand_wheel"]
                  }
                },
                "required": ["variant_id", "label", "competitive_strategy", "positioning", "brand"]
              }
            }
          },
          "required": ["variants"]
        }
