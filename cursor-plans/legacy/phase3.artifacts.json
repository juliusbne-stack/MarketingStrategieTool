                      "type": { "type": "string", "enum": ["cost", "differentiation", "focus", "hybrid"] },
                      "rationale": { "type": "string", "maxLength": 220 },
                      "tradeoffs": { "type": "array", "items": { "type": "string" }, "maxItems": 3 }
                    },
                    "required": ["type", "rationale", "tradeoffs"]
