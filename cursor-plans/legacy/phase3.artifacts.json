                      "canvas": {
                        "type": "object",
                        "properties": {
                          "target": { "type": "string", "maxLength": 120 },
                          "problem": { "type": "string", "maxLength": 140 },
                          "outcome": { "type": "string", "maxLength": 140 },
                          "approach": { "type": "string", "maxLength": 160 },
                          "proof": { "type": "string", "maxLength": 140 }
                        },
                        "required": ["target", "problem", "outcome", "approach", "proof"]
                      }
                    },
                    "required": ["statement", "market_role", "differentiation", "canvas"]
                  },
